# Application
PROJECT_NAME=CuisineEnsemble
ENVIRONMENT=development
SECRET_KEY=change-this-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UVICORN_WORKERS=2

# PostgreSQL
POSTGRES_DB=cuisineensemble
POSTGRES_USER=cuisine_user
POSTGRES_PASSWORD=cuisine_password
DATABASE_URL=postgresql+psycopg2://cuisine_user:cuisine_password@db:5432/cuisineensemble

# Frontend and CORS
VITE_API_BASE=/api
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# Network bindings
# Local and VPS: internal tools stay reachable only from the host itself.
HOST_BIND=127.0.0.1
# The public website listens on all interfaces.
HTTP_BIND=0.0.0.0

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
